ANTHROPIC_API_KEY=sk-ant-...
OPENROUTER_API_KEY=             # required when WORKER_PROVIDER=openrouter or ORCHESTRATOR_PROVIDER=openrouter

# ── Orchestrator (planning + review) ─────────────────────────────────────────
ORCHESTRATOR_PROVIDER=anthropic          # "anthropic" | "openrouter"
ORCHESTRATOR_MODEL=claude-sonnet-4-6
ORCHESTRATOR_API_MODEL=openrouter/auto   # used when ORCHESTRATOR_PROVIDER=openrouter

# ── Worker (code writing) ─────────────────────────────────────────────────────
# Use "ollama" for local GPU execution (free, lower quality on complex tasks).
# Use "anthropic" to write code with Claude — higher quality, costs API tokens.
# Use "openrouter" for any cloud model via OpenRouter.
WORKER_PROVIDER=ollama
WORKER_MODEL=qwen2.5-coder:14b

# Examples:
#   WORKER_PROVIDER=anthropic   WORKER_MODEL=claude-haiku-4-5-20251001   (fast + cheap)
#   WORKER_PROVIDER=anthropic   WORKER_MODEL=claude-sonnet-4-6            (best quality)
#   WORKER_PROVIDER=openrouter  WORKER_MODEL=openrouter/auto              (auto-routed)
#   WORKER_PROVIDER=ollama      WORKER_MODEL=qwen2.5-coder:7b             (local, 8GB VRAM)

# Fallback chain tried in order when primary fails (rate limit, connection error, etc.)
# Format: "provider::model,provider::model"
WORKER_FALLBACKS=openrouter::openrouter/auto,ollama::qwen2.5-coder:7b

# ── Misc ──────────────────────────────────────────────────────────────────────
PROJECTS_DIR=./projects
MAX_RETRIES_PER_TASK=3
MAX_FORMAT5_DEPTH=3
MAX_PARALLEL_WORKERS=2
OLLAMA_HOST=http://localhost:11434
