ANTHROPIC_API_KEY=sk-ant-...
OPENROUTER_API_KEY=             # optional — needed only if ORCHESTRATOR_PROVIDER=openrouter
GOOGLE_API_KEY=                 # optional — needed only if ORCHESTRATOR_PROVIDER=gemini
                                # (aistudio.google.com — free tier: 1M tokens/day on gemini-2.5-flash)

# ── Auth (JWT secret for generated full-stack apps with auth tasks) ───────────
# Change this to a long random string before deploying any generated app.
# Generated projects read JWT_SECRET from their own .env; this entry here
# pre-populates the harness config and can be forwarded to project .env.example files.
JWT_SECRET=change-me-to-a-long-random-secret-at-least-32-chars

# ── Orchestrator (planning + review) ──────────────────────────────────────────
ORCHESTRATOR_PROVIDER=anthropic          # "anthropic" | "openrouter" | "gemini"
ORCHESTRATOR_MODEL=claude-sonnet-4-6
ORCHESTRATOR_API_MODEL=openrouter/auto   # used when ORCHESTRATOR_PROVIDER=openrouter
GEMINI_ORCHESTRATOR_MODEL=gemini-2.5-flash  # used when ORCHESTRATOR_PROVIDER=gemini
                                            # (calls Google directly so the free tier applies)

# Emergency orchestrator fallback: when ORCHESTRATOR_PROVIDER=gemini and Gemini exhausts all
# retries, automatically route the same call through Anthropic Sonnet instead of dying.
# This lets a quota-outage build complete (~$0.50) instead of crashing with no output.
# Disable by setting ORCHESTRATOR_EMERGENCY_PROVIDER= (empty).
# The default is "anthropic" when ANTHROPIC_API_KEY is set, otherwise "" (disabled).
# ORCHESTRATOR_EMERGENCY_PROVIDER=anthropic
# EMERGENCY_ORCHESTRATOR_MODEL=claude-sonnet-4-6

# ── Role model overrides (default to Haiku — cheaper, fine for these tasks) ──
# These roles do short focused calls and don't need Sonnet/Opus reasoning power.
# Change to claude-sonnet-4-6 or claude-opus-4-8 for higher quality at higher cost.
CREATIVE_DIRECTOR_MODEL=claude-haiku-4-5-20251001    # intent → creative brief
TECHNICAL_ARCHITECT_MODEL=claude-haiku-4-5-20251001  # brief → tech spec + ADRs
FINAL_REVIEW_MODEL=claude-haiku-4-5-20251001         # stub/dep/syntax checks (1-4×/build)
EXECUTION_ERROR_MODEL=claude-haiku-4-5-20251001      # error triage per failed task

# ── Worker (code writing) — local Ollama model ────────────────────────────────
# The worker is always a local model running via Ollama.
# Claude is the orchestrator/reviewer only — never the bulk worker.
WORKER_PROVIDER=ollama
WORKER_MODEL=deepseek-coder-v2:16b       # ~8.9 GB VRAM at Q4_0, ~90% HumanEval (superseded by WORKER_LADDER)
# WORKER_MODEL=qwen2.5-coder:14b         # legacy primary — ~8.4 GB VRAM
# WORKER_MODEL=qwen3:8b                  # ~5 GB VRAM (lighter local option)

# Complexity router ladder (weakest → strongest). Each task starts on a LOCAL rung by
# complexity; on retry it escalates one rung up (cloud only after a local failure).
# Format: "provider::model,provider::model". Empty disables laddering.
# Opus 4.8 ($5/$25 per MTok, ~1.67x Sonnet) is the last-resort rung: reachable only after
# deepseek AND Sonnet have failed the same task, carrying full error context + triage hints.
# Paid rungs (Sonnet + Opus) share the MAX_PAID_WORKER_CALLS budget below.
WORKER_LADDER=ollama::qwen3:8b,ollama::deepseek-coder-v2:16b,anthropic::claude-sonnet-4-6,anthropic::claude-opus-4-8
# Hard cap on paid (cloud) worker calls per project run — escalation clamps to local past this.
MAX_PAID_WORKER_CALLS=15

# ── Codex CLI worker rung (OAuth / flat-rate escalation) ──────────────────────
# Inserts a `codex::<model>` rung BETWEEN the strongest local rung and the paid
# Anthropic rungs. Codex bills against your ChatGPT Plus/Pro subscription (OAuth,
# flat-rate) — NOT per token — so escalations that would otherwise spend Anthropic
# dollars are caught for free first. This rung does NOT consume MAX_PAID_WORKER_CALLS
# (the dollar budget); it has its own per-run capacity counter (CODEX_CLI_MAX_CALLS).
# If Codex is unavailable (not logged in / quota hit / exe missing / 401 / 429) the
# rung is skipped cleanly and escalation continues to the next rung — the build never
# blocks on interactive reauth. Requires the `codex` CLI installed and a logged-in
# ChatGPT session visible to the worker subprocess (see CODEX_HOME).
#
# Example ladder WITH the Codex OAuth rung (uncomment to enable):
# WORKER_LADDER=ollama::qwen3:8b,ollama::deepseek-coder-v2:16b,codex::gpt-5.5,anthropic::claude-sonnet-4-6,anthropic::claude-opus-4-8
#
CODEX_CLI_ENABLED=false              # master switch for the codex:: OAuth rung (default: off)
CODEX_MODEL=gpt-5.5                  # model passed to `codex exec` for this rung
CODEX_EFFORT=medium                  # reasoning effort: "low" | "medium" | "high"
CODEX_CLI_MAX_CALLS=10               # per-run capacity cap for OAuth codex calls (separate from the dollar budget)
CODEX_TIMEOUT=180                    # seconds before a single `codex exec` subprocess is killed (fail-fast skip)
# CODEX_HOME=                        # path to the Codex profile/auth dir passed into the worker subprocess env;
                                     # set this if the worker subprocess can't see your interactive ChatGPT login

# Legacy fallback chain (used only when WORKER_LADDER is empty): try a free OpenRouter
# model, then a local model. Format: "provider::model,provider::model"
WORKER_FALLBACKS=openrouter::qwen/qwen-2.5-coder-32b-instruct:free,ollama::qwen3:8b

# ── Misc ──────────────────────────────────────────────────────────────────────
PROJECTS_DIR=./projects
MAX_RETRIES_PER_TASK=3
MAX_FORMAT5_DEPTH=3
MAX_PARALLEL_WORKERS=2
OLLAMA_HOST=http://localhost:11434

# ── Asset generation — local Stable Diffusion (optional) ──────────────────
# Generates real sprites/icons via a LOCAL Stable Diffusion WebUI instance.
# Works with AUTOMATIC1111, Forge, or ComfyUI (A1111-compat API).
# No cloud API key needed — runs entirely on your GPU.
#
# To enable: start SD WebUI with --api flag, then run j-claw normally.
# SD_API_URL=http://localhost:7860   # default — change if SD runs on a different port
# ASSET_PROVIDER=sd                 # "sd" | "none"  (default: sd)
#
# If SD WebUI is not running, SVG color-block placeholders are written instead.

# ── Audio generation — local Coqui TTS (optional) ─────────────────────────
# Generates .wav sound effects and TTS audio via a LOCAL Coqui TTS server.
# No cloud API key needed — runs entirely on your CPU/GPU.
#
# To enable: start Coqui TTS server (https://github.com/coqui-ai/TTS)
# COQUI_API_URL=http://localhost:5002   # default — change if TTS runs on a different port
#
# If Coqui TTS is not running, silent WAV placeholders are written instead.

# ── Deployment hook (optional) ─────────────────────────────────────────────
# Set DEPLOY_HOOK to a CLI command that deploys the generated project.
# Runs in the project output directory after git commit.
# Leave unset to skip deployment (default).
#
# Examples:
#   DEPLOY_HOOK=vercel --prod --yes          # Vercel (requires: npm i -g vercel + vercel login)
#   DEPLOY_HOOK=netlify deploy --prod        # Netlify (requires: npm i -g netlify-cli + netlify login)
#   DEPLOY_HOOK=railway up                   # Railway
#
# DEPLOY_TIMEOUT=120   # seconds before the hook is killed (default: 120)

# ── Experience tracker (optional) ────────────────────────────────────────────
# Logs EXECUTION_ERROR outcomes locally to improve future retry quality.
# No external APIs — fully local JSONL file.
# EXPERIENCE_LOG=experience.jsonl   # path relative to harness/ working dir

# ── Orchestrator output tokens (optional) ─────────────────────────────────
# Raise if the orchestrator truncates large task DAGs (default is fine for most projects).
# ORCHESTRATOR_MAX_TOKENS=16384

# ── Telegram bot (optional) ────────────────────────────────────────────────
# Run `python start_bot.py` (or bot.bat) to start the Telegram control interface.
# Get a token from @BotFather, and your chat ID from @userinfobot.
#
# TELEGRAM_BOT_TOKEN=         # BotFather token
# TELEGRAM_CHAT_ID=           # Your chat ID (get it from @userinfobot)

# ── IPFS / Pinata (optional, web3 projects) ───────────────────────────────
# After a web3 pipeline run, j-claw will automatically run scripts/pin-to-ipfs.js
# and append the resulting CID to HANDOFF.md.
# Requires IPFS_AUTO_PIN=true and valid Pinata credentials.
#
PINATA_API_KEY=           # Pinata API key for IPFS pinning (web3 projects)
PINATA_SECRET_KEY=        # Pinata secret API key
IPFS_AUTO_PIN=false       # Set true to auto-pin web3 builds to IPFS via Pinata
