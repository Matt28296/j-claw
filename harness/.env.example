ANTHROPIC_API_KEY=sk-ant-...
WORKER_PROVIDER=ollama          # "ollama" | "groq" | "openrouter"
WORKER_MODEL=qwen2.5-coder:7b  # ollama: qwen2.5-coder:7b | groq: qwen-qwen2-5-coder-32b-instruct | openrouter: qwen/qwen-2.5-coder-32b-instruct:free
GROQ_API_KEY=                   # required when WORKER_PROVIDER=groq (console.groq.com)
OPENROUTER_API_KEY=             # required when WORKER_PROVIDER=openrouter (openrouter.ai)
PROJECTS_DIR=./projects
MAX_RETRIES_PER_TASK=3
MAX_FORMAT5_DEPTH=3
OLLAMA_HOST=http://localhost:11434
