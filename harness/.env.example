ANTHROPIC_API_KEY=sk-ant-...
OPENROUTER_API_KEY=             # optional — needed only if ORCHESTRATOR_PROVIDER=openrouter

# ── Orchestrator (planning + review) — Claude only ────────────────────────────
ORCHESTRATOR_PROVIDER=anthropic          # "anthropic" | "openrouter"
ORCHESTRATOR_MODEL=claude-sonnet-4-6
ORCHESTRATOR_API_MODEL=openrouter/auto   # used when ORCHESTRATOR_PROVIDER=openrouter

# ── Worker (code writing) — local Ollama model ────────────────────────────────
# The worker is always a local model running via Ollama.
# Claude is the orchestrator/reviewer only — never the worker.
WORKER_PROVIDER=ollama
WORKER_MODEL=qwen2.5-coder:14b           # 8–16 GB VRAM at Q4
# WORKER_MODEL=qwen2.5-coder:7b          # 8 GB VRAM

# Fallback chain: if Ollama is unavailable, try a free OpenRouter model (non-Claude).
# Format: "provider::model,provider::model"
WORKER_FALLBACKS=openrouter::qwen/qwen-2.5-coder-32b-instruct:free,ollama::qwen2.5-coder:7b

# ── Misc ──────────────────────────────────────────────────────────────────────
PROJECTS_DIR=./projects
MAX_RETRIES_PER_TASK=3
MAX_FORMAT5_DEPTH=3
MAX_PARALLEL_WORKERS=2
OLLAMA_HOST=http://localhost:11434

# ── Asset generation — local Stable Diffusion (optional) ──────────────────
# Generates real sprites/icons via a LOCAL Stable Diffusion WebUI instance.
# Works with AUTOMATIC1111, Forge, or ComfyUI (A1111-compat API).
# No cloud API key needed — runs entirely on your GPU.
#
# To enable: start SD WebUI with --api flag, then run j-claw normally.
# SD_API_URL=http://localhost:7860   # default — change if SD runs on a different port
# ASSET_PROVIDER=sd                 # "sd" | "none"  (default: sd)
#
# If SD WebUI is not running, SVG color-block placeholders are written instead.

# ── Deployment hook (optional) ─────────────────────────────────────────────
# Set DEPLOY_HOOK to a CLI command that deploys the generated project.
# Runs in the project output directory after git commit.
# Leave unset to skip deployment (default).
#
# Examples:
#   DEPLOY_HOOK=vercel --prod --yes          # Vercel (requires: npm i -g vercel + vercel login)
#   DEPLOY_HOOK=netlify deploy --prod        # Netlify (requires: npm i -g netlify-cli + netlify login)
#   DEPLOY_HOOK=railway up                   # Railway
#
# DEPLOY_TIMEOUT=120   # seconds before the hook is killed (default: 120)

# ── Orchestrator output tokens (optional) ─────────────────────────────────
# Raise if the orchestrator truncates large task DAGs (default is fine for most projects).
# ORCHESTRATOR_MAX_TOKENS=16384
